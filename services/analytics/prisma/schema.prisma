datasource db {
  provider = "sqlite"
  url      = "file:./analytics.db"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model AuditLog {
  id               String   @id @default(uuid())
  eventId          String
  type             String
  payload          String   // JSON stringified payload
  timestamp        DateTime
  service          String
  createdAt        DateTime @default(now())
}

model Metric {
  key       String @id
  value     String
}
