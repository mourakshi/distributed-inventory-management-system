datasource db {
  provider = "sqlite"
  url      = "file:./inventory.db"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model ProductStock {
  id        String   @id @default(uuid())
  productId String   @unique
  name      String
  quantity  Int
  warehouse String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
